# Copy this file to .env and fill in real local values.
# Never commit .env.

# Required secrets/tokens
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
PREFERENCES_AI_API_KEY=
STRIPE_SECRET_KEY=

# Optional Stripe webhook signature secret
STRIPE_WEBHOOK_SECRET=

# Runtime configuration
PORT=4242
DOMAIN=http://localhost:4242
DISCORD_GUILD_ID=
NGROK_URL=https://your-ngrok-domain.ngrok-free.dev
MANIFEST_PATH=./active_session.json
PREFERENCES_API_BASE=https://dashboard.preferencesai.io/api/v1
PREFERENCES_SIMULATION_PRU_COST=29
PREFERENCES_REQUEST_TIMEOUT=180
HERMES_PREVIEW_USE_CLI=1
HERMES_PREVIEW_TIMEOUT=90
