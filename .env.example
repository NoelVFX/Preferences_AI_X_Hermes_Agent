# Public web server
PORT=4242
# Set this to your final HTTPS URL, for example https://203-0-113-10.sslip.io
DOMAIN=https://your-public-domain.example
# The Discord coordinator uses this as the Checkout/webhook base URL. Keep it equal to DOMAIN in cloud.
NGROK_URL=https://your-public-domain.example

# Stripe test/live keys
STRIPE_SECRET_KEY=sk_test_...
# Create this after adding the Stripe webhook endpoint: https://your-domain/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Preferences AI
PREFERENCES_API_BASE=https://dashboard.preferencesai.io/api/v1
PREFERENCES_AI_API_KEY=...
PREFERENCES_SIMULATION_PRU_COST=29
PREFERENCES_REQUEST_TIMEOUT=180

# Hermes preview generation
# On a minimal cloud VM, keep this off unless Hermes CLI is installed/configured there.
HERMES_PREVIEW_USE_CLI=0
HERMES_COMMAND=hermes
HERMES_PREVIEW_TIMEOUT=90

# Discord bot/coordinator. Required only if running agent_coordinator.py.
DISCORD_BOT_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional app behavior
WEB_RUN_LIVE_SIMULATION=1
WEB_REQUIRE_PAYMENT_FOR_DASHBOARD_LINKS=1
WEB_PRICE_CENTS=999
WEB_PRICE_CURRENCY=usd
WEB_PRODUCT_NAME=Preferences AI Blueprint Matrix
